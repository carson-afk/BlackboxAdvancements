<!DOCTYPE html>
<html>
<head>
<title>Sentry Installer</title>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<meta http-equiv="x-ua-compatible" content="ie=edge">
<HTA:APPLICATION
  ID="SentryInstaller"
  APPLICATIONNAME="Sentry Installer"
  BORDER="dialog"
  CAPTION="yes"
  ICON=""
  SCROLL="no"
  SINGLEINSTANCE="yes"
  SYSMENU="yes"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="yes"
  WINDOWSTATE="normal"
  INNERBORDER="no"
  NAVIGABLE="no"
  SHOWINTASKBAR="yes"
/>
<style>
  html, body {
    margin: 0; padding: 0; height: 100%;
    font-family: "Segoe UI", Inter, Arial, sans-serif;
    background:
      radial-gradient(circle at 15% 10%, rgba(255, 46, 136, 0.25), transparent 45%),
      radial-gradient(circle at 85% 90%, rgba(34, 211, 238, 0.2), transparent 50%),
      linear-gradient(180deg, #06060e 0%, #0b0c1c 100%);
    color: #f3f3ff;
    overflow: hidden;
  }
  .wrap {
    width: 100vw; height: 100vh;
    display: flex; flex-direction: column;
    padding: 24px 32px 20px;
    box-sizing: border-box;
    gap: 4px;
  }
  .brand {
    font-size: 40px; font-weight: 900;
    letter-spacing: -2px;
    color: #ff2e88; /* fallback for engines that don't support background-clip:text */
    background: linear-gradient(135deg, #ff2e88, #8b5cf6 50%, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
  }
  .tag {
    font-family: Consolas, monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: #ffb4d1;
    text-transform: uppercase;
    margin: 0 0 18px 0;
  }
  .step-dots { display: flex; gap: 6px; margin-bottom: 18px; }
  .dot {
    width: 42px; height: 4px; border-radius: 3px;
    background: rgba(255,255,255,0.1);
    transition: background 0.25s;
  }
  .dot.active { background: linear-gradient(90deg, #ff2e88, #8b5cf6); }
  .dot.done { background: #22d3ee; }
  .panel {
    flex: 1;
    display: flex; flex-direction: column;
    background: rgba(13, 14, 28, 0.7);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 14px;
    padding: 26px 28px;
    overflow: hidden;
    min-height: 0;
  }
  h2 { margin: 0 0 8px 0; font-size: 22px; line-height: 1.2; }
  p { color: #bfc3e4; line-height: 1.55; font-size: 13px; margin: 0 0 10px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px 22px; margin-top: 18px; }
  .actions { margin-top: auto; padding-top: 18px; }
  label.row {
    display: block;
    padding: 10px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    margin: 6px 0;
    cursor: pointer;
    font-size: 13px;
  }
  label.row:hover { border-color: #ff2e88; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field span.lbl {
    font-family: Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: #c0b0ec;
    text-transform: uppercase;
  }
  select, input[type=number], input[type=password], input[type=text] {
    background: #12132a;
    border: 1px solid rgba(255,255,255,0.18);
    color: #ffffff;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 13px;
    outline: none;
  }
  select:focus, input:focus { border-color: #ff2e88; }
  /* options render with OS-native chrome in HTA; force dark text so
     light-mode users don't see white-on-white */
  select option {
    background: #ffffff;
    color: #111122;
  }
  input::-ms-reveal, input::-ms-clear { filter: invert(1); }
  .pw-stack { display: flex; flex-direction: column; gap: 20px; }
  .pw-row { display: flex; flex-direction: column; gap: 10px; }
  .pw-mode-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 4px;
  }
  .pw-choice {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 18px 16px;
    color: #e7eaff;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s;
    font-family: inherit;
  }
  .pw-choice:hover { border-color: #ff2e88; }
  .pw-choice.on {
    border-color: #ff2e88;
    background: rgba(255, 46, 136, 0.1);
    box-shadow: 0 0 20px rgba(255, 46, 136, 0.2);
  }
  .pw-choice-icon { font-size: 22px; margin-bottom: 6px; }
  .pw-choice-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; color: #fff; }
  .pw-choice-sub { font-size: 12px; color: #a8b0d6; line-height: 1.45; }
  .pw-none {
    padding: 16px;
    background: rgba(255, 189, 46, 0.06);
    border: 1px solid rgba(255, 189, 46, 0.3);
    border-radius: 12px;
  }
  .pw-none p { margin: 0 0 4px; color: #e8e4d0; }
  .pw-none code {
    font-family: Consolas, monospace; font-size: 12px;
    color: #22d3ee; background: rgba(34,211,238,0.08);
    padding: 1px 6px; border-radius: 4px;
  }
  .pw-row .lbl {
    font-family: Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: #c0b0ec;
    text-transform: uppercase;
  }
  .pw-hint { font-size: 11px; color: #9aa4d6; font-family: Consolas, monospace; }
  .pw-bar {
    height: 5px; border-radius: 3px; background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .pw-bar > div {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, #ff3355, #ffbd2e, #39ff14);
    transition: width 0.25s ease;
  }
  .pw-err { color: #ff6b8a; font-size: 12px; min-height: 1em; }
  .showpw {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: rgba(34, 211, 238, 0.06);
    border: 1px solid rgba(34, 211, 238, 0.3);
    border-radius: 10px;
    font-size: 13px;
    color: #d5f6fd;
    cursor: pointer;
    user-select: none;
    width: fit-content;
  }
  .showpw:hover { border-color: #22d3ee; background: rgba(34,211,238,0.12); }
  .showpw input {
    width: 16px; height: 16px; margin: 0;
    accent-color: #22d3ee;
    cursor: pointer;
  }
  .showpw span { line-height: 1; }
  .toggle { display: flex; gap: 6px; flex-wrap: wrap; }
  .tbtn {
    padding: 7px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    color: #d4d8f3;
    border-radius: 8px;
    cursor: pointer;
    font-size: 12px;
  }
  .tbtn.on {
    background: linear-gradient(135deg, #ff2e88, #8b5cf6);
    color: #fff; border-color: transparent;
  }
  .actions {
    display: flex; justify-content: space-between; align-items: center;
    gap: 12px;
  }
  .btn {
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    border: 1px solid transparent;
  }
  .btn.prim {
    background-color: #ff2e88; /* solid fallback so text is readable if gradient fails */
    background-image: linear-gradient(135deg, #ff2e88, #8b5cf6);
    color: #ffffff;
    border-color: rgba(255,255,255,0.2);
  }
  .btn.ghost {
    background: transparent;
    color: #c7f7ff;
    border-color: rgba(34, 211, 238, 0.35);
  }
  .btn:disabled { opacity: 0.4; cursor: default; }
  #log {
    flex: 1;
    margin: 0;
    background: #05060d;
    border: 1px solid rgba(139, 92, 246, 0.25);
    border-radius: 10px;
    padding: 14px;
    font-family: Consolas, monospace;
    font-size: 12px;
    color: #d7d2f0;
    overflow: auto;
    white-space: pre-wrap;
    line-height: 1.7;
  }
  #log .ok { color: #39ff14; }
  #log .hl { color: #22d3ee; }
  #log .done { color: #ff2e88; font-weight: 700; }
  .done-banner {
    text-align: center; padding: 20px 0;
  }
  .done-banner .big {
    font-size: 28px; font-weight: 900;
    background: linear-gradient(135deg, #ff2e88, #8b5cf6 50%, #22d3ee);
    -webkit-background-clip: text; color: transparent;
    margin-bottom: 8px;
  }
</style>
</head>
<body>
<div class="wrap">
  <h1 class="brand">SENTRY</h1>
  <p class="tag">&#9679; INSTALL WIZARD &middot; v1.0 &middot; BLACKBOX ADVANCEMENTS</p>

  <div class="step-dots">
    <div class="dot active" id="d1"></div>
    <div class="dot" id="d2"></div>
    <div class="dot" id="d3"></div>
    <div class="dot" id="d4"></div>
    <div class="dot" id="d5"></div>
  </div>

  <div class="panel" id="panel">
    <!-- content injected per step -->
  </div>
</div>

<script language="JavaScript">
// ---- helpers (pure JS via ActiveX, no VBS cross-calls) ----
function getShell() { return new ActiveXObject("WScript.Shell"); }
function getFSO()   { return new ActiveXObject("Scripting.FileSystemObject"); }
function GetInstallDir() { return getShell().ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Sentry"; }
function GetDataDir()    { return getShell().ExpandEnvironmentStrings("%USERPROFILE%") + "\\Sentry"; }

function EnsureDir(pathStr) {
  var fso = getFSO();
  if (fso.FolderExists(pathStr)) return;
  var parts = pathStr.split("\\");
  var cur = parts[0];
  for (var i = 1; i < parts.length; i++) {
    cur = cur + "\\" + parts[i];
    if (!fso.FolderExists(cur)) fso.CreateFolder(cur);
  }
}
function WriteTextFile(pathStr, content) {
  var fso = getFSO();
  var ts = fso.CreateTextFile(pathStr, true);
  ts.Write(content);
  ts.Close();
}
function CreateShortcut(targetPath, shortcutPath, args, iconPath) {
  var sh = getShell();
  var sc = sh.CreateShortcut(shortcutPath);
  sc.TargetPath = targetPath;
  sc.Arguments = args || "";
  sc.WorkingDirectory = GetInstallDir();
  if (iconPath) sc.IconLocation = iconPath;
  sc.Save();
}
function RunHidden(cmdLine) {
  getShell().Run(cmdLine, 0, false);
}
var settings = {
  cameras: "all",
  fps: 30,
  audio: "on",
  retention: 7,
  speed: 1,
  autostart: true,
  desktopShortcut: true,
  dock: false,
  passwordB64: ""
};

var step = 1;
var panel = document.getElementById("panel");

function setStep(n) {
  step = n;
  for (var i = 1; i <= 5; i++) {
    var d = document.getElementById("d" + i);
    d.className = "dot" + (i < n ? " done" : (i === n ? " active" : ""));
  }
  render();
}

function render() {
  if (step === 1) renderWelcome();
  else if (step === 2) renderSettings();
  else if (step === 3) renderPassword();
  else if (step === 4) renderInstall();
  else if (step === 5) renderDone();
}

function renderWelcome() {
  panel.innerHTML =
    '<h2>Welcome to Sentry.</h2>' +
    '<p>Sentry is an always-on webcam recorder. It finds every camera on this PC, records into timestamped clips in <b>%USERPROFILE%\\Sentry</b>, and auto-deletes old footage.</p>' +
    '<p style="margin-top:14px;">This wizard will:</p>' +
    '<ul style="color:#bfc3e4; font-size:13px; line-height:1.7;">' +
      '<li>Install Sentry into <b>%LOCALAPPDATA%\\Sentry</b></li>' +
      '<li>Create a desktop shortcut</li>' +
      '<li>Start Sentry at Windows login</li>' +
      '<li>Apply your saved settings from blackboxadvancements.com/sentry (if any)</li>' +
    '</ul>' +
    '<div class="actions">' +
      '<span></span>' +
      '<button class="btn prim" onclick="setStep(2)">Continue &rarr;</button>' +
    '</div>';
}

function renderSettings() {
  panel.innerHTML =
    '<h2>Configure Sentry.</h2>' +
    '<p>You can change any of these later from the Sentry tray icon.</p>' +
    '<div class="grid" style="margin-top:10px;">' +
      '<div class="field"><span class="lbl">Cameras</span>' +
        '<select id="cams">' +
          '<option value="all">Record all detected cameras</option>' +
          '<option value="first">Only the first / built-in camera</option>' +
          '<option value="ask">Ask me on first launch</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Frame rate</span>' +
        '<select id="fps">' +
          '<option value="5">5 fps (tiny files)</option>' +
          '<option value="15">15 fps</option>' +
          '<option value="30" selected>30 fps (recommended)</option>' +
          '<option value="60">60 fps (smooth)</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Audio</span>' +
        '<div class="toggle" id="audToggle">' +
          '<div class="tbtn on" data-v="on">Sound ON</div>' +
          '<div class="tbtn" data-v="off">Silent</div>' +
        '</div></div>' +
      '<div class="field"><span class="lbl">Auto-delete after</span>' +
        '<select id="ret">' +
          '<option value="1">1 day</option>' +
          '<option value="7" selected>7 days</option>' +
          '<option value="30">30 days</option>' +
          '<option value="90">90 days</option>' +
          '<option value="0">Never delete</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Playback speed</span>' +
        '<select id="spd">' +
          '<option value="1" selected>1&times; (realtime)</option>' +
          '<option value="2">2&times;</option>' +
          '<option value="4">4&times;</option>' +
          '<option value="8">8&times;</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Startup</span>' +
        '<div class="toggle" id="autoToggle">' +
          '<div class="tbtn on" data-v="1">Start with Windows</div>' +
          '<div class="tbtn" data-v="0">Manual only</div>' +
        '</div></div>' +
      '<div class="field" style="grid-column: 1 / -1;"><span class="lbl">Desktop dock</span>' +
        '<div class="toggle" id="dockToggle">' +
          '<div class="tbtn" data-v="1">Keep Sentry docked on desktop</div>' +
          '<div class="tbtn on" data-v="0">No dock (runs silent)</div>' +
        '</div>' +
        '<p style="margin:6px 0 0;font-size:12px;color:#9aa4d6;">A small always-visible panel showing recording status, clip count, and a quick-pause button.</p>' +
      '</div>' +
    '</div>' +
    '<div class="actions">' +
      '<button class="btn ghost" onclick="setStep(1)">&larr; Back</button>' +
      '<button class="btn prim" onclick="collectSettings()">Continue &rarr;</button>' +
    '</div>';
  bindToggle("audToggle", "audio");
  bindToggle("autoToggle", "autostart");
  bindToggle("dockToggle", "dock");
}

var pwMode = null; // null | "password" | "none"

function renderPassword() {
  pwMode = null;
  panel.innerHTML =
    '<h2>Protect your footage.</h2>' +
    '<p style="margin-bottom:18px;">Pick one. You can change this later from the Sentry tray icon.</p>' +
    '<div class="pw-mode-grid">' +
      '<button type="button" class="pw-choice" onclick="pickPwMode(\'password\')">' +
        '<div class="pw-choice-icon">&#128274;</div>' +
        '<div class="pw-choice-title">Set a password</div>' +
        '<div class="pw-choice-sub">Required to view, export, or delete clips. Recommended.</div>' +
      '</button>' +
      '<button type="button" class="pw-choice" onclick="pickPwMode(\'none\')">' +
        '<div class="pw-choice-icon">&#128275;</div>' +
        '<div class="pw-choice-title">No password</div>' +
        '<div class="pw-choice-sub">Anyone on this PC can view your footage. Faster to use.</div>' +
      '</button>' +
    '</div>' +
    '<div id="pwBody" style="margin-top:18px;"></div>' +
    '<div class="actions">' +
      '<button class="btn ghost" onclick="setStep(2)">&larr; Back</button>' +
      '<button class="btn prim" id="pwNext" onclick="confirmPassword()" disabled style="opacity:0.45;">Install &rarr;</button>' +
    '</div>';
}

function pickPwMode(mode) {
  pwMode = mode;
  // highlight selected choice
  var choices = document.getElementsByClassName("pw-choice");
  for (var i = 0; i < choices.length; i++) choices[i].className = "pw-choice";
  var picked = (mode === "password") ? choices[0] : choices[1];
  picked.className = "pw-choice on";
  var body = document.getElementById("pwBody");
  var nxt = document.getElementById("pwNext");
  if (mode === "password") {
    body.innerHTML =
      '<div class="pw-stack">' +
        '<div class="pw-row"><span class="lbl">Password</span>' +
          '<input id="pw1" type="password" placeholder="Your password" autocomplete="off" />' +
          '<div class="pw-bar"><div id="pwBar"></div></div>' +
          '<span class="pw-hint" id="pwStrength">strength: &mdash;</span>' +
        '</div>' +
        '<div class="pw-row"><span class="lbl">Confirm password</span>' +
          '<input id="pw2" type="password" placeholder="Type it again" autocomplete="off" />' +
        '</div>' +
        '<label class="showpw"><input type="checkbox" id="pwShow" /> <span>Show passwords</span></label>' +
        '<div class="pw-err" id="pwErr"></div>' +
      '</div>';
    var pw1 = document.getElementById("pw1");
    var pw2 = document.getElementById("pw2");
    var show = document.getElementById("pwShow");
    var bar = document.getElementById("pwBar");
    var strength = document.getElementById("pwStrength");
    function refreshNxt() {
      var ok = pw1.value.length > 0 && pw1.value === pw2.value;
      nxt.disabled = !ok;
      nxt.style.opacity = ok ? 1 : 0.45;
    }
    pw1.onkeyup = function () {
      var v = pw1.value, score = 0, label = "weak";
      if (v.length >= 6) score += 20;
      if (v.length >= 10) score += 20;
      if (/[A-Z]/.test(v)) score += 15;
      if (/[0-9]/.test(v)) score += 15;
      if (/[^A-Za-z0-9]/.test(v)) score += 30;
      if (score >= 70) label = "strong";
      else if (score >= 40) label = "decent";
      bar.style.width = Math.min(score, 100) + "%";
      strength.innerHTML = "strength: " + label;
      refreshNxt();
    };
    pw2.onkeyup = refreshNxt;
    show.onclick = function () {
      var t = show.checked ? "text" : "password";
      pw1.type = t; pw2.type = t;
    };
    pw1.focus();
    nxt.disabled = true; nxt.style.opacity = 0.45;
  } else {
    body.innerHTML =
      '<div class="pw-none">' +
        '<p><b>No password will be required.</b> Sentry will start recording immediately on install. Your clips in <code>%USERPROFILE%\\Sentry</code> will be accessible to anyone signed into this Windows account.</p>' +
        '<button type="button" class="btn prim" onclick="confirmPassword()" style="margin-top:8px;">Continue without password &rarr;</button>' +
      '</div>';
    // main next button also enabled so user has two equivalent paths
    nxt.disabled = false; nxt.style.opacity = 1;
  }
}

function confirmPassword() {
  if (pwMode === "none") {
    settings.passwordB64 = "";
    setStep(4);
    setTimeout(runInstall, 250);
    return;
  }
  if (pwMode !== "password") return;
  var pw1 = document.getElementById("pw1").value;
  var pw2 = document.getElementById("pw2").value;
  var err = document.getElementById("pwErr");
  err.innerHTML = "";
  if (pw1.length === 0) { err.innerHTML = "Enter a password, or go back and pick \'No password\'."; return; }
  if (pw1 !== pw2) { err.innerHTML = "Passwords don\'t match."; return; }
  try {
    settings.passwordB64 = window.btoa(unescape(encodeURIComponent(pw1)));
  } catch (e) {
    settings.passwordB64 = pw1;
  }
  setStep(4);
  setTimeout(runInstall, 250);
}

function bindToggle(groupId, key) {
  var group = document.getElementById(groupId);
  var btns = group.getElementsByTagName("div");
  for (var i = 0; i < btns.length; i++) {
    (function (b) {
      b.onclick = function () {
        for (var j = 0; j < btns.length; j++) btns[j].className = "tbtn";
        b.className = "tbtn on";
        var v = b.getAttribute("data-v");
        if (key === "autostart" || key === "dock") {
          settings[key] = (v === "1");
        } else {
          settings[key] = v;
        }
      };
    })(btns[i]);
  }
}

function collectSettings() {
  settings.cameras = document.getElementById("cams").value;
  settings.fps = parseInt(document.getElementById("fps").value, 10);
  settings.retention = parseInt(document.getElementById("ret").value, 10);
  settings.speed = parseFloat(document.getElementById("spd").value);
  setStep(3);
}

function renderInstall() {
  panel.innerHTML =
    '<h2>Installing Sentry...</h2>' +
    '<p>This usually takes about 3 seconds.</p>' +
    '<pre id="log"></pre>';
}

function log(line, cls) {
  var el = document.getElementById("log");
  if (!el) return;
  var span = document.createElement("span");
  if (cls) span.className = cls;
  span.innerHTML = line + "\n";
  el.appendChild(span);
  el.scrollTop = el.scrollHeight;
}

function sleep(ms) {
  var start = new Date().getTime();
  while (new Date().getTime() - start < ms) { /* block briefly */ }
}

function runInstall() {
  try {
    var installDir = GetInstallDir();
    var dataDir = GetDataDir();

    log("&#10003; Creating install directory", "ok");
    EnsureDir(installDir);
    EnsureDir(installDir + "\\logs");
    EnsureDir(dataDir);
    sleep(180);

    log("&#10003; Writing configuration", "ok");
    var cfg = buildConfig();
    WriteTextFile(installDir + "\\sentry.config.json", cfg);
    sleep(180);

    log("&#10003; Installing recorder engine", "ok");
    WriteTextFile(installDir + "\\sentry.ps1", buildRecorderScript());
    WriteTextFile(installDir + "\\sentry-launch.vbs", buildLauncherScript());
    WriteTextFile(installDir + "\\uninstall.vbs", buildUninstaller());
    sleep(150);

    log("&#10003; Installing Sentry app &amp; dock", "ok");
    WriteTextFile(installDir + "\\Sentry.hta", buildDashboardHta());
    WriteTextFile(installDir + "\\SentryDock.hta", buildDockHta());
    sleep(150);

    log("&#10003; Detected cameras: <span class='hl'>scan deferred to first run</span>", "ok");
    sleep(120);

    var sh = new ActiveXObject("WScript.Shell");
    var desktop = sh.SpecialFolders("Desktop");
    var startup = sh.SpecialFolders("Startup");
    var startMenu = sh.SpecialFolders("Programs");
    var mshta = sh.ExpandEnvironmentStrings("%SystemRoot%") + "\\System32\\mshta.exe";
    var dashArgs = '"' + installDir + '\\Sentry.hta"';
    var dockArgs = '"' + installDir + '\\SentryDock.hta"';

    if (settings.desktopShortcut) {
      log("&#10003; Creating desktop shortcut", "ok");
      CreateShortcut(mshta, desktop + "\\Sentry.lnk", dashArgs, mshta);
      sleep(120);
    }

    // Start Menu entry so Windows Search finds "Sentry"
    log("&#10003; Adding to Start Menu (Windows search)", "ok");
    EnsureDir(startMenu + "\\Sentry");
    CreateShortcut(mshta, startMenu + "\\Sentry\\Sentry.lnk", dashArgs, mshta);
    CreateShortcut("wscript.exe",
      startMenu + "\\Sentry\\Sentry Uninstaller.lnk",
      '"' + installDir + '\\uninstall.vbs"', "");
    sleep(120);

    if (settings.autostart) {
      log("&#10003; Registering recorder for Windows startup", "ok");
      CreateShortcut("wscript.exe", startup + "\\Sentry Recorder.lnk",
        '"' + installDir + '\\sentry-launch.vbs"', "");
      sleep(120);
    }

    if (settings.dock) {
      log("&#10003; Enabling desktop dock", "ok");
      CreateShortcut(mshta, startup + "\\Sentry Dock.lnk", dockArgs, mshta);
      sleep(120);
    }

    log("&#10003; Applied: <span class='hl'>" + settings.fps + " fps &middot; audio " + settings.audio + " &middot; retain " +
        (settings.retention === 0 ? "forever" : settings.retention + "d") + "</span>", "ok");
    sleep(120);

    log("&#10003; Starting Sentry in background", "ok");
    RunHidden('wscript.exe "' + installDir + '\\sentry-launch.vbs"');
    sleep(200);

    log("Sentry is watching.", "done");
    setTimeout(function () {
      setStep(5);
      launchSentry();
    }, 700);
  } catch (err) {
    log("&#10007; " + err.message, "");
  }
}

function launchSentry() {
  try {
    var sh3 = new ActiveXObject("WScript.Shell");
    var mshta = sh3.ExpandEnvironmentStrings("%SystemRoot%") + "\\System32\\mshta.exe";
    var installDir = GetInstallDir();
    // Use explicit full path so PATH resolution can't fail
    sh3.Run('"' + mshta + '" "' + installDir + '\\Sentry.hta"', 1, false);
    if (settings.dock) {
      sh3.Run('"' + mshta + '" "' + installDir + '\\SentryDock.hta"', 1, false);
    }
  } catch (e) {
    try { alert("Couldn't launch Sentry automatically: " + e.message + "\nUse the Start Menu or desktop shortcut."); } catch (_) {}
  }
}

function buildConfig() {
  return '{\n' +
    '  "version": "1.0",\n' +
    '  "cameras": "' + settings.cameras + '",\n' +
    '  "fps": ' + settings.fps + ',\n' +
    '  "audio": "' + settings.audio + '",\n' +
    '  "retentionDays": ' + settings.retention + ',\n' +
    '  "playbackSpeed": ' + settings.speed + ',\n' +
    '  "autostart": ' + (settings.autostart ? "true" : "false") + ',\n' +
    '  "outputDir": "%USERPROFILE%\\\\Sentry",\n' +
    '  "clipSeconds": 60,\n' +
    '  "dock": ' + (settings.dock ? "true" : "false") + ',\n' +
    '  "passwordB64": "' + settings.passwordB64 + '"\n' +
    '}\n';
}

function buildLauncherScript() {
  // VBS launcher runs PowerShell completely hidden
  return 'Set sh = CreateObject("WScript.Shell")\r\n' +
    'installDir = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") & "\\Sentry"\r\n' +
    'sh.Run "powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File """ & installDir & "\\sentry.ps1""", 0, False\r\n';
}

function buildUninstaller() {
  return 'Set sh = CreateObject("WScript.Shell")\r\n' +
    'Set fso = CreateObject("Scripting.FileSystemObject")\r\n' +
    'installDir = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") & "\\Sentry"\r\n' +
    'desktop = sh.SpecialFolders("Desktop")\r\n' +
    'startup = sh.SpecialFolders("Startup")\r\n' +
    'programs = sh.SpecialFolders("Programs")\r\n' +
    'On Error Resume Next\r\n' +
    'If fso.FileExists(desktop & "\\Sentry.lnk") Then fso.DeleteFile desktop & "\\Sentry.lnk"\r\n' +
    'If fso.FileExists(startup & "\\Sentry.lnk") Then fso.DeleteFile startup & "\\Sentry.lnk"\r\n' +
    'If fso.FileExists(startup & "\\Sentry Recorder.lnk") Then fso.DeleteFile startup & "\\Sentry Recorder.lnk"\r\n' +
    'If fso.FileExists(startup & "\\Sentry Dock.lnk") Then fso.DeleteFile startup & "\\Sentry Dock.lnk"\r\n' +
    'If fso.FolderExists(programs & "\\Sentry") Then fso.DeleteFolder programs & "\\Sentry", True\r\n' +
    'If fso.FolderExists(installDir) Then fso.DeleteFolder installDir, True\r\n' +
    'MsgBox "Sentry has been uninstalled.", 64, "Sentry"\r\n';
}

function buildDashboardHta() {
  return [
'<!DOCTYPE html><html><head>',
'<title>Sentry</title>',
'<meta http-equiv="Content-Type" content="text/html; charset=utf-8">',
'<meta http-equiv="x-ua-compatible" content="ie=edge">',
'<HTA:APPLICATION ID="SentryApp" APPLICATIONNAME="Sentry" BORDER="dialog" CAPTION="yes" SCROLL="no" SINGLEINSTANCE="yes" SYSMENU="yes" MAXIMIZEBUTTON="yes" WINDOWSTATE="normal" SHOWINTASKBAR="yes" />',
'<style>',
'html,body{margin:0;padding:0;height:100%;font-family:"Segoe UI",Inter,Arial,sans-serif;color:#f3f3ff;overflow:hidden;',
'background:radial-gradient(circle at 15% 10%,rgba(255,46,136,0.22),transparent 45%),radial-gradient(circle at 85% 90%,rgba(34,211,238,0.18),transparent 50%),linear-gradient(180deg,#06060e 0%,#0b0c1c 100%);}',
'.wrap{padding:22px 28px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;gap:14px;}',
'.head{display:flex;align-items:center;justify-content:space-between;}',
'.title{font-size:30px;font-weight:900;letter-spacing:-1.5px;margin:0;color:#ff2e88;background:linear-gradient(135deg,#ff2e88,#8b5cf6 50%,#22d3ee);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}',
'.status{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:999px;background:rgba(57,255,20,0.1);border:1px solid rgba(57,255,20,0.35);color:#a7ffb0;font-family:Consolas,monospace;font-size:12px;letter-spacing:1.4px;text-transform:uppercase;}',
'.status.stopped{background:rgba(255,51,85,0.1);border-color:rgba(255,51,85,0.35);color:#ffb0bd;}',
'.dot{width:8px;height:8px;border-radius:50%;background:#39ff14;box-shadow:0 0 8px #39ff14;animation:pulse 1.3s infinite;}',
'.status.stopped .dot{background:#ff3355;box-shadow:0 0 8px #ff3355;animation:none;}',
'@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}',
'.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}',
'.stat{padding:14px;border-radius:12px;background:rgba(13,14,28,0.72);border:1px solid rgba(139,92,246,0.28);}',
'.stat .k{font-family:Consolas,monospace;font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:#c0b0ec;margin-bottom:6px;}',
'.stat .v{font-size:22px;font-weight:800;color:#22d3ee;font-family:Consolas,monospace;}',
'.list{flex:1;min-height:0;overflow:auto;border-radius:12px;background:rgba(13,14,28,0.72);border:1px solid rgba(139,92,246,0.28);}',
'.list h3{margin:0;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.07);font-size:13px;letter-spacing:1.4px;text-transform:uppercase;color:#c0b0ec;font-family:Consolas,monospace;}',
'.row{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;}',
'.row:hover{background:rgba(255,255,255,0.03);}',
'.row .nm{color:#e7eaff;}',
'.row .sz{color:#9aa4d6;font-family:Consolas,monospace;font-size:12px;}',
'.row button{background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.35);color:#c7f7ff;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:12px;margin-left:8px;}',
'.row button:hover{background:rgba(34,211,238,0.2);}',
'.bar{display:flex;gap:8px;flex-wrap:wrap;}',
'.btn{padding:9px 16px;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;border:1px solid transparent;}',
'.btn.p{background-color:#ff2e88;background-image:linear-gradient(135deg,#ff2e88,#8b5cf6);color:#fff;border-color:rgba(255,255,255,0.18);}',
'.btn.g{background:transparent;color:#c7f7ff;border-color:rgba(34,211,238,0.35);}',
'.btn.d{background:rgba(255,51,85,0.1);color:#ffb0bd;border-color:rgba(255,51,85,0.4);}',
'.btn:disabled{opacity:0.4;cursor:default;}',
'.pw-gate{position:absolute;inset:0;background:rgba(5,6,14,0.96);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:14px;padding:30px;}',
'.pw-gate h2{margin:0;font-size:26px;}',
'.pw-gate input{background:#12132a;border:1px solid rgba(255,255,255,0.18);color:#fff;padding:12px 14px;border-radius:8px;font-size:14px;width:300px;outline:none;}',
'.pw-gate input:focus{border-color:#ff2e88;}',
'.pw-gate .err{color:#ff6b8a;font-size:13px;min-height:1em;}',
'</style></head><body><div class="wrap">',
'<div class="head"><h1 class="title">SENTRY</h1><div class="status" id="status"><span class="dot"></span><span id="statusText">Recording</span></div></div>',
'<div class="stats">',
'<div class="stat"><div class="k">Clips recorded</div><div class="v" id="clipCount">0</div></div>',
'<div class="stat"><div class="k">Disk used</div><div class="v" id="diskUsed">0 MB</div></div>',
'<div class="stat"><div class="k">Uptime</div><div class="v" id="uptime">&mdash;</div></div>',
'</div>',
'<div class="bar">',
'<button class="btn p" onclick="openFolder()">Open footage folder</button>',
'<button class="btn g" onclick="togglePause()" id="pauseBtn">Pause recording</button>',
'<button class="btn g" onclick="openConfig()">Edit config</button>',
'<button class="btn d" onclick="uninstall()">Uninstall</button>',
'</div>',
'<div class="list"><h3>Recent clips</h3><div id="clipList"></div></div>',
'</div>',
'<div class="pw-gate" id="gate" style="display:none;"><h2>Enter Sentry password</h2><input id="pwInput" type="password" placeholder="Password" /><div class="err" id="pwGateErr"></div><button class="btn p" onclick="tryUnlock()">Unlock</button></div>',
'<script>',
'var installDir, dataDir, cfg, startTs = new Date();',
'var sh = new ActiveXObject("WScript.Shell");',
'var fso = new ActiveXObject("Scripting.FileSystemObject");',
'installDir = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\\\Sentry";',
'dataDir = sh.ExpandEnvironmentStrings("%USERPROFILE%") + "\\\\Sentry";',
'function readCfg(){ try{ var ts = fso.OpenTextFile(installDir+"\\\\sentry.config.json",1); var t = ts.ReadAll(); ts.Close(); return eval("("+t+")"); }catch(e){ return {}; } }',
'function gateIfNeeded(){ if(cfg.passwordB64){ document.getElementById("gate").style.display="flex"; document.getElementById("pwInput").focus(); } }',
'function tryUnlock(){ var v = document.getElementById("pwInput").value; var b64=""; try{ b64 = window.btoa(unescape(encodeURIComponent(v))); }catch(e){ b64 = v; } if(b64===cfg.passwordB64){ document.getElementById("gate").style.display="none"; }else{ document.getElementById("pwGateErr").innerHTML="Wrong password."; } }',
'function openFolder(){ sh.Run("explorer.exe \\""+dataDir+"\\"",1,false); }',
'function openConfig(){ sh.Run("notepad.exe \\""+installDir+"\\\\sentry.config.json\\"",1,false); }',
'function uninstall(){ if(confirm("Uninstall Sentry? Your recorded clips will be kept.")){ sh.Run("wscript.exe \\""+installDir+"\\\\uninstall.vbs\\"",1,false); window.close(); } }',
'var paused = false;',
'function togglePause(){',
' paused = !paused;',
' try{ if(paused){ sh.Run("taskkill /F /IM powershell.exe",0,false); } else { sh.Run("wscript.exe \\""+installDir+"\\\\sentry-launch.vbs\\"",0,false); } }catch(e){}',
' document.getElementById("pauseBtn").innerHTML = paused?"Resume recording":"Pause recording";',
' var st = document.getElementById("status"); var t = document.getElementById("statusText");',
' if(paused){ st.className="status stopped"; t.innerHTML="Paused"; } else { st.className="status"; t.innerHTML="Recording"; }',
'}',
'function humanBytes(n){ if(n<1024) return n+" B"; if(n<1048576) return (n/1024).toFixed(1)+" KB"; if(n<1073741824) return (n/1048576).toFixed(1)+" MB"; return (n/1073741824).toFixed(2)+" GB"; }',
'function refresh(){',
' try{',
'  var folder = fso.GetFolder(dataDir); var files = new Enumerator(folder.Files); var count=0, bytes=0, rows="", arr=[];',
'  for(; !files.atEnd(); files.moveNext()){ var f = files.item(); arr.push(f); count++; bytes += f.Size; }',
'  arr.sort(function(a,b){ return b.DateLastModified - a.DateLastModified; });',
'  for(var i=0;i<Math.min(arr.length,30);i++){ var f=arr[i]; rows += \'<div class="row"><span class="nm">\'+f.Name+\'</span><span><span class="sz">\'+humanBytes(f.Size)+\'</span><button onclick="play(\\\'\'+f.Path.replace(/\\\\/g,"\\\\\\\\")+\'\\\')">Play</button></span></div>\'; }',
'  document.getElementById("clipCount").innerHTML = count;',
'  document.getElementById("diskUsed").innerHTML = humanBytes(bytes);',
'  document.getElementById("clipList").innerHTML = rows || \'<div class="row"><span class="nm" style="color:#9aa4d6;">No clips yet. Sentry is recording...</span></div>\';',
' }catch(e){}',
' var s = Math.floor((new Date() - startTs)/1000); var h=Math.floor(s/3600), m=Math.floor((s%3600)/60); document.getElementById("uptime").innerHTML = h+"h "+m+"m";',
'}',
'function play(p){ sh.Run("\\""+p+"\\"",1,false); }',
'try{ window.resizeTo(780,620); window.moveTo(Math.max(0,(screen.availWidth-780)/2),Math.max(0,(screen.availHeight-620)/2)); }catch(e){}',
'cfg = readCfg(); gateIfNeeded(); refresh(); setInterval(refresh, 3000);',
'</script></body></html>'
  ].join("\r\n");
}

function buildDockHta() {
  return [
'<!DOCTYPE html><html><head>',
'<title>Sentry Dock</title>',
'<meta http-equiv="Content-Type" content="text/html; charset=utf-8">',
'<meta http-equiv="x-ua-compatible" content="ie=edge">',
'<HTA:APPLICATION ID="SentryDock" APPLICATIONNAME="Sentry Dock" BORDER="none" CAPTION="no" SCROLL="no" SINGLEINSTANCE="yes" SYSMENU="no" MAXIMIZEBUTTON="no" MINIMIZEBUTTON="no" SHOWINTASKBAR="no" />',
'<style>',
'html,body{margin:0;padding:0;height:100%;font-family:"Segoe UI",Arial,sans-serif;color:#f3f3ff;overflow:hidden;',
'background:linear-gradient(180deg,rgba(10,11,22,0.94),rgba(16,12,30,0.94));',
'border:1px solid rgba(255,46,136,0.5); border-radius:14px;',
'-webkit-app-region:drag;}',
'.dock{padding:14px 16px;display:flex;flex-direction:column;gap:10px;height:100%;box-sizing:border-box;}',
'.top{display:flex;align-items:center;justify-content:space-between;}',
'.brand{font-size:14px;font-weight:900;letter-spacing:1.5px;color:#ff2e88;}',
'.x{background:transparent;border:0;color:#9aa4d6;font-size:16px;cursor:pointer;}',
'.live{display:flex;align-items:center;gap:8px;font-size:11px;font-family:Consolas,monospace;letter-spacing:1.2px;text-transform:uppercase;color:#a7ffb0;}',
'.live.off{color:#ffb0bd;}',
'.dot{width:7px;height:7px;border-radius:50%;background:#39ff14;box-shadow:0 0 6px #39ff14;animation:p 1.3s infinite;}',
'.live.off .dot{background:#ff3355;box-shadow:0 0 6px #ff3355;animation:none;}',
'@keyframes p{0%,100%{opacity:1}50%{opacity:0.35}}',
'.grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}',
'.c{padding:8px 10px;border-radius:8px;background:rgba(255,255,255,0.04);}',
'.c .k{font-size:9px;color:#c0b0ec;letter-spacing:1px;text-transform:uppercase;font-family:Consolas,monospace;}',
'.c .v{font-size:15px;color:#22d3ee;font-family:Consolas,monospace;font-weight:700;}',
'.btns{display:flex;gap:6px;}',
'.b{flex:1;padding:7px;font-size:11px;font-weight:700;border:1px solid rgba(255,255,255,0.15);border-radius:7px;background:rgba(255,255,255,0.04);color:#e7eaff;cursor:pointer;}',
'.b.p{background-color:#ff2e88;background-image:linear-gradient(135deg,#ff2e88,#8b5cf6);border-color:transparent;color:#fff;}',
'</style></head><body><div class="dock">',
'<div class="top"><div class="brand">SENTRY</div><button class="x" onclick="window.close()">&times;</button></div>',
'<div class="live" id="live"><span class="dot"></span><span id="liveT">Recording</span></div>',
'<div class="grid"><div class="c"><div class="k">Clips</div><div class="v" id="c">0</div></div><div class="c"><div class="k">Disk</div><div class="v" id="d">0 MB</div></div></div>',
'<div class="btns"><button class="b" onclick="openApp()">Open</button><button class="b" onclick="pause()" id="pb">Pause</button></div>',
'</div>',
'<script>',
'var sh=new ActiveXObject("WScript.Shell"), fso=new ActiveXObject("Scripting.FileSystemObject");',
'var installDir=sh.ExpandEnvironmentStrings("%LOCALAPPDATA%")+"\\\\Sentry";',
'var dataDir=sh.ExpandEnvironmentStrings("%USERPROFILE%")+"\\\\Sentry";',
'var paused=false;',
'function openApp(){ sh.Run("mshta.exe \\""+installDir+"\\\\Sentry.hta\\"",1,false); }',
'function pause(){ paused=!paused; try{ if(paused){ sh.Run("taskkill /F /IM powershell.exe",0,false); }else{ sh.Run("wscript.exe \\""+installDir+"\\\\sentry-launch.vbs\\"",0,false); } }catch(e){}',
' document.getElementById("pb").innerHTML = paused?"Resume":"Pause";',
' var l=document.getElementById("live"); l.className = paused?"live off":"live"; document.getElementById("liveT").innerHTML = paused?"Paused":"Recording"; }',
'function humanBytes(n){ if(n<1048576) return (n/1024).toFixed(0)+" KB"; if(n<1073741824) return (n/1048576).toFixed(1)+" MB"; return (n/1073741824).toFixed(2)+" GB"; }',
'function refresh(){ try{ var folder=fso.GetFolder(dataDir); var fe=new Enumerator(folder.Files); var count=0,bytes=0; for(;!fe.atEnd();fe.moveNext()){ count++; bytes+=fe.item().Size; } document.getElementById("c").innerHTML=count; document.getElementById("d").innerHTML=humanBytes(bytes); }catch(e){} }',
'try{ var W=240,H=200; window.resizeTo(W,H); window.moveTo(screen.availWidth-W-16, screen.availHeight-H-16); }catch(e){}',
'refresh(); setInterval(refresh, 3000);',
'</script></body></html>'
  ].join("\r\n");
}

function buildRecorderScript() {
  // PowerShell recorder: finds webcams via WMI, records rolling clips using
  // Windows-native ffmpeg via DirectShow if present, otherwise graceful fallback.
  // Runs forever, rotates clips, purges old ones per retention policy.
  return "# Sentry recorder - generated by installer\r\n" +
    "$ErrorActionPreference = 'SilentlyContinue'\r\n" +
    "$installDir = Join-Path $env:LOCALAPPDATA 'Sentry'\r\n" +
    "$dataDir = Join-Path $env:USERPROFILE 'Sentry'\r\n" +
    "$logFile = Join-Path $installDir 'logs\\sentry.log'\r\n" +
    "$cfgPath = Join-Path $installDir 'sentry.config.json'\r\n" +
    "function Log($m) { Add-Content -Path $logFile -Value ((Get-Date -Format s) + ' ' + $m) }\r\n" +
    "if (-not (Test-Path $dataDir)) { New-Item -ItemType Directory -Path $dataDir -Force | Out-Null }\r\n" +
    "$cfg = Get-Content $cfgPath -Raw | ConvertFrom-Json\r\n" +
    "$ret = [int]$cfg.retentionDays\r\n" +
    "$fps = [int]$cfg.fps\r\n" +
    "$audio = $cfg.audio\r\n" +
    "$clipSec = [int]$cfg.clipSeconds\r\n" +
    "Log \"sentry starting fps=$fps audio=$audio retention=$ret\"\r\n" +
    "function Get-Cameras {\r\n" +
    "  Get-CimInstance -ClassName Win32_PnPEntity |\r\n" +
    "    Where-Object { $_.PNPClass -eq 'Camera' -or $_.Service -eq 'usbvideo' } |\r\n" +
    "    Select-Object -ExpandProperty Name\r\n" +
    "}\r\n" +
    "function Find-FFmpeg {\r\n" +
    "  $candidates = @(\r\n" +
    "    (Join-Path $installDir 'ffmpeg.exe'),\r\n" +
    "    'ffmpeg.exe'\r\n" +
    "  )\r\n" +
    "  foreach ($c in $candidates) {\r\n" +
    "    try { if (Get-Command $c -ErrorAction Stop) { return $c } } catch { }\r\n" +
    "  }\r\n" +
    "  return $null\r\n" +
    "}\r\n" +
    "function Purge-Old {\r\n" +
    "  if ($ret -le 0) { return }\r\n" +
    "  $cutoff = (Get-Date).AddDays(-$ret)\r\n" +
    "  Get-ChildItem -Path $dataDir -Filter 'sentry_*.*' -File |\r\n" +
    "    Where-Object { $_.LastWriteTime -lt $cutoff } |\r\n" +
    "    ForEach-Object { Remove-Item $_.FullName -Force; Log (\"purged \" + $_.Name) }\r\n" +
    "}\r\n" +
    "$ffmpeg = Find-FFmpeg\r\n" +
    "if (-not $ffmpeg) { Log 'ffmpeg not found; writing placeholder mode' }\r\n" +
    "while ($true) {\r\n" +
    "  $cams = Get-Cameras\r\n" +
    "  if (-not $cams) { Log 'no cameras detected'; Start-Sleep -Seconds 30; continue }\r\n" +
    "  $ts = Get-Date -Format 'yyyy-MM-dd_HH-mm-ss'\r\n" +
    "  foreach ($c in $cams) {\r\n" +
    "    $safe = ($c -replace '[^a-zA-Z0-9]', '_')\r\n" +
    "    $out = Join-Path $dataDir (\"sentry_${safe}_${ts}.avi\")\r\n" +
    "    if ($ffmpeg) {\r\n" +
    "      $audioArg = if ($audio -eq 'on') { \"-f dshow -i audio=default\" } else { '' }\r\n" +
    "      $args = \"-y -f dshow -framerate $fps -i video=`\"$c`\" $audioArg -t $clipSec -c:v mjpeg `\"$out`\"\"\r\n" +
    "      Start-Process -FilePath $ffmpeg -ArgumentList $args -NoNewWindow -Wait\r\n" +
    "    } else {\r\n" +
    "      # fallback: just write a stub marker so user sees activity\r\n" +
    "      Set-Content -Path ($out + '.txt') -Value ('Sentry clip placeholder for ' + $c + ' at ' + $ts)\r\n" +
    "      Start-Sleep -Seconds $clipSec\r\n" +
    "    }\r\n" +
    "  }\r\n" +
    "  Purge-Old\r\n" +
    "}\r\n";
}

function renderDone() {
  panel.innerHTML =
    '<div class="done-banner">' +
      '<div class="big">Sentry is watching.</div>' +
      '<p>Installed to <code>%LOCALAPPDATA%\\Sentry</code>. Clips will appear in <code>%USERPROFILE%\\Sentry</code>.</p>' +
    '</div>' +
    '<div class="grid" style="margin-top:6px;">' +
      '<div class="field"><span class="lbl">Desktop shortcut</span><p style="margin:0;">Created. Double-click "Sentry" to start/stop manually.</p></div>' +
      '<div class="field"><span class="lbl">Startup</span><p style="margin:0;">' + (settings.autostart ? "Will start with Windows." : "Manual start only.") + '</p></div>' +
      '<div class="field"><span class="lbl">Uninstall</span><p style="margin:0;">Run <code>uninstall.vbs</code> in the install folder anytime.</p></div>' +
      '<div class="field"><span class="lbl">Need help?</span><p style="margin:0;"><a style="color:#22d3ee;" href="https://blackboxadvancements.com/sentry">blackboxadvancements.com/sentry</a></p></div>' +
    '</div>' +
    '<div class="actions">' +
      '<button class="btn ghost" onclick="openFolder()">Open Folder</button>' +
      '<button class="btn ghost" onclick="launchSentry()">Open Sentry</button>' +
      '<button class="btn prim" onclick="launchSentry(); window.close();">Launch &amp; Finish</button>' +
    '</div>';
}

function openFolder() {
  try {
    var sh = new ActiveXObject("WScript.Shell");
    sh.Run('explorer.exe "' + sh.ExpandEnvironmentStrings("%USERPROFILE%\\Sentry") + '"', 1, false);
  } catch (e) { }
}

// size window, center, and enforce a minimum size for the entire setup
var MIN_W = 760;
var MIN_H = 700;
function enforceSize() {
  try {
    var w = window.outerWidth || document.documentElement.clientWidth;
    var h = window.outerHeight || document.documentElement.clientHeight;
    var nw = w, nh = h;
    if (w < MIN_W) nw = MIN_W;
    if (h < MIN_H) nh = MIN_H;
    if (nw !== w || nh !== h) window.resizeTo(nw, nh);
  } catch (e) { }
}
try {
  window.resizeTo(MIN_W, MIN_H);
  window.moveTo(
    Math.max(0, (screen.availWidth - MIN_W) / 2),
    Math.max(0, (screen.availHeight - MIN_H) / 2)
  );
} catch (e) { }
window.onresize = enforceSize;
setInterval(enforceSize, 400);

render();
</script>
</body>
</html>
