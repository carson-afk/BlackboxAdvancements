<!DOCTYPE html>
<html>
<head>
<title>Sentry Installer</title>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<meta http-equiv="x-ua-compatible" content="ie=edge">
<HTA:APPLICATION
  ID="SentryInstaller"
  APPLICATIONNAME="Sentry Installer"
  BORDER="dialog"
  CAPTION="yes"
  ICON=""
  SCROLL="no"
  SINGLEINSTANCE="yes"
  SYSMENU="yes"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="yes"
  WINDOWSTATE="normal"
  INNERBORDER="no"
  NAVIGABLE="no"
  SHOWINTASKBAR="yes"
/>
<style>
  html, body {
    margin: 0; padding: 0; height: 100%;
    font-family: "Segoe UI", Inter, Arial, sans-serif;
    background:
      radial-gradient(circle at 15% 10%, rgba(255, 46, 136, 0.25), transparent 45%),
      radial-gradient(circle at 85% 90%, rgba(34, 211, 238, 0.2), transparent 50%),
      linear-gradient(180deg, #06060e 0%, #0b0c1c 100%);
    color: #f3f3ff;
    overflow: hidden;
  }
  .wrap {
    width: 100vw; height: 100vh;
    display: flex; flex-direction: column;
    padding: 24px 32px 20px;
    box-sizing: border-box;
    gap: 4px;
  }
  .brand {
    font-size: 40px; font-weight: 900;
    letter-spacing: -2px;
    color: #ff2e88; /* fallback for engines that don't support background-clip:text */
    background: linear-gradient(135deg, #ff2e88, #8b5cf6 50%, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
  }
  .tag {
    font-family: Consolas, monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: #ffb4d1;
    text-transform: uppercase;
    margin: 0 0 18px 0;
  }
  .step-dots { display: flex; gap: 6px; margin-bottom: 18px; }
  .dot {
    width: 42px; height: 4px; border-radius: 3px;
    background: rgba(255,255,255,0.1);
    transition: background 0.25s;
  }
  .dot.active { background: linear-gradient(90deg, #ff2e88, #8b5cf6); }
  .dot.done { background: #22d3ee; }
  .panel {
    flex: 1;
    display: flex; flex-direction: column;
    background: rgba(13, 14, 28, 0.7);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 14px;
    padding: 26px 28px;
    overflow: hidden;
    min-height: 0;
  }
  h2 { margin: 0 0 8px 0; font-size: 22px; line-height: 1.2; }
  p { color: #bfc3e4; line-height: 1.55; font-size: 13px; margin: 0 0 10px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px 22px; margin-top: 18px; }
  .actions { margin-top: auto; padding-top: 18px; }
  label.row {
    display: block;
    padding: 10px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    margin: 6px 0;
    cursor: pointer;
    font-size: 13px;
  }
  label.row:hover { border-color: #ff2e88; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field span.lbl {
    font-family: Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: #c0b0ec;
    text-transform: uppercase;
  }
  select, input[type=number], input[type=password], input[type=text] {
    background: #12132a;
    border: 1px solid rgba(255,255,255,0.18);
    color: #ffffff;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 13px;
    outline: none;
  }
  select:focus, input:focus { border-color: #ff2e88; }
  /* options render with OS-native chrome in HTA; force dark text so
     light-mode users don't see white-on-white */
  select option {
    background: #ffffff;
    color: #111122;
  }
  input::-ms-reveal, input::-ms-clear { filter: invert(1); }
  .pw-stack { display: flex; flex-direction: column; gap: 20px; }
  .pw-row { display: flex; flex-direction: column; gap: 10px; }
  .pw-mode-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 4px;
  }
  .pw-choice {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 18px 16px;
    color: #e7eaff;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s;
    font-family: inherit;
  }
  .pw-choice:hover { border-color: #ff2e88; }
  .pw-choice.on {
    border-color: #ff2e88;
    background: rgba(255, 46, 136, 0.1);
    box-shadow: 0 0 20px rgba(255, 46, 136, 0.2);
  }
  .pw-choice-icon { font-size: 22px; margin-bottom: 6px; }
  .pw-choice-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; color: #fff; }
  .pw-choice-sub { font-size: 12px; color: #a8b0d6; line-height: 1.45; }
  .pw-none {
    padding: 16px;
    background: rgba(255, 189, 46, 0.06);
    border: 1px solid rgba(255, 189, 46, 0.3);
    border-radius: 12px;
  }
  .pw-none p { margin: 0 0 4px; color: #e8e4d0; }
  .pw-none code {
    font-family: Consolas, monospace; font-size: 12px;
    color: #22d3ee; background: rgba(34,211,238,0.08);
    padding: 1px 6px; border-radius: 4px;
  }
  .pw-row .lbl {
    font-family: Consolas, monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: #c0b0ec;
    text-transform: uppercase;
  }
  .pw-hint { font-size: 11px; color: #9aa4d6; font-family: Consolas, monospace; }
  .pw-bar {
    height: 5px; border-radius: 3px; background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .pw-bar > div {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, #ff3355, #ffbd2e, #39ff14);
    transition: width 0.25s ease;
  }
  .pw-err { color: #ff6b8a; font-size: 12px; min-height: 1em; }
  .showpw {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: rgba(34, 211, 238, 0.06);
    border: 1px solid rgba(34, 211, 238, 0.3);
    border-radius: 10px;
    font-size: 13px;
    color: #d5f6fd;
    cursor: pointer;
    user-select: none;
    width: fit-content;
  }
  .showpw:hover { border-color: #22d3ee; background: rgba(34,211,238,0.12); }
  .showpw input {
    width: 16px; height: 16px; margin: 0;
    accent-color: #22d3ee;
    cursor: pointer;
  }
  .showpw span { line-height: 1; }
  .toggle { display: flex; gap: 6px; flex-wrap: wrap; }
  .tbtn {
    padding: 7px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    color: #d4d8f3;
    border-radius: 8px;
    cursor: pointer;
    font-size: 12px;
  }
  .tbtn.on {
    background: linear-gradient(135deg, #ff2e88, #8b5cf6);
    color: #fff; border-color: transparent;
  }
  .actions {
    display: flex; justify-content: space-between; align-items: center;
    gap: 12px;
  }
  .btn {
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    border: 1px solid transparent;
  }
  .btn.prim {
    background-color: #ff2e88; /* solid fallback so text is readable if gradient fails */
    background-image: linear-gradient(135deg, #ff2e88, #8b5cf6);
    color: #ffffff;
    border-color: rgba(255,255,255,0.2);
  }
  .btn.ghost {
    background: transparent;
    color: #c7f7ff;
    border-color: rgba(34, 211, 238, 0.35);
  }
  .btn:disabled { opacity: 0.4; cursor: default; }
  #log {
    flex: 1;
    margin: 0;
    background: #05060d;
    border: 1px solid rgba(139, 92, 246, 0.25);
    border-radius: 10px;
    padding: 14px;
    font-family: Consolas, monospace;
    font-size: 12px;
    color: #d7d2f0;
    overflow: auto;
    white-space: pre-wrap;
    line-height: 1.7;
  }
  #log .ok { color: #39ff14; }
  #log .hl { color: #22d3ee; }
  #log .done { color: #ff2e88; font-weight: 700; }
  .done-banner {
    text-align: center; padding: 20px 0;
  }
  .done-banner .big {
    font-size: 28px; font-weight: 900;
    background: linear-gradient(135deg, #ff2e88, #8b5cf6 50%, #22d3ee);
    -webkit-background-clip: text; color: transparent;
    margin-bottom: 8px;
  }
</style>
</head>
<body>
<div class="wrap">
  <h1 class="brand">SENTRY</h1>
  <p class="tag">&#9679; INSTALL WIZARD &middot; v1.0 &middot; BLACKBOX ADVANCEMENTS</p>

  <div class="step-dots">
    <div class="dot active" id="d1"></div>
    <div class="dot" id="d2"></div>
    <div class="dot" id="d3"></div>
    <div class="dot" id="d4"></div>
    <div class="dot" id="d5"></div>
  </div>

  <div class="panel" id="panel">
    <!-- content injected per step -->
  </div>
</div>

<script language="JavaScript">
// ---- helpers (pure JS via ActiveX, no VBS cross-calls) ----
function getShell() { return new ActiveXObject("WScript.Shell"); }
function getFSO()   { return new ActiveXObject("Scripting.FileSystemObject"); }
function GetInstallDir() { return getShell().ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Sentry"; }
function GetDataDir()    { return getShell().ExpandEnvironmentStrings("%USERPROFILE%") + "\\Sentry"; }

function EnsureDir(pathStr) {
  var fso = getFSO();
  if (fso.FolderExists(pathStr)) return;
  var parts = pathStr.split("\\");
  var cur = parts[0];
  for (var i = 1; i < parts.length; i++) {
    cur = cur + "\\" + parts[i];
    if (!fso.FolderExists(cur)) fso.CreateFolder(cur);
  }
}
function WriteTextFile(pathStr, content) {
  var fso = getFSO();
  var ts = fso.CreateTextFile(pathStr, true);
  ts.Write(content);
  ts.Close();
}
function CreateShortcut(targetPath, shortcutPath, args, iconPath) {
  var sh = getShell();
  var sc = sh.CreateShortcut(shortcutPath);
  sc.TargetPath = targetPath;
  sc.Arguments = args || "";
  sc.WorkingDirectory = GetInstallDir();
  if (iconPath) sc.IconLocation = iconPath;
  sc.Save();
}
function RunHidden(cmdLine) {
  getShell().Run(cmdLine, 0, false);
}
var settings = {
  cameras: "all",
  fps: 30,
  audio: "on",
  retention: 7,
  speed: 1,
  autostart: true,
  desktopShortcut: true,
  passwordB64: ""
};

var step = 1;
var panel = document.getElementById("panel");

function setStep(n) {
  step = n;
  for (var i = 1; i <= 5; i++) {
    var d = document.getElementById("d" + i);
    d.className = "dot" + (i < n ? " done" : (i === n ? " active" : ""));
  }
  render();
}

function render() {
  if (step === 1) renderWelcome();
  else if (step === 2) renderSettings();
  else if (step === 3) renderPassword();
  else if (step === 4) renderInstall();
  else if (step === 5) renderDone();
}

function renderWelcome() {
  panel.innerHTML =
    '<h2>Welcome to Sentry.</h2>' +
    '<p>Sentry is an always-on webcam recorder. It finds every camera on this PC, records into timestamped clips in <b>%USERPROFILE%\\Sentry</b>, and auto-deletes old footage.</p>' +
    '<p style="margin-top:14px;">This wizard will:</p>' +
    '<ul style="color:#bfc3e4; font-size:13px; line-height:1.7;">' +
      '<li>Install Sentry into <b>%LOCALAPPDATA%\\Sentry</b></li>' +
      '<li>Create a desktop shortcut</li>' +
      '<li>Start Sentry at Windows login</li>' +
      '<li>Apply your saved settings from blackboxadvancements.com/sentry (if any)</li>' +
    '</ul>' +
    '<div class="actions">' +
      '<span></span>' +
      '<button class="btn prim" onclick="setStep(2)">Continue &rarr;</button>' +
    '</div>';
}

function renderSettings() {
  panel.innerHTML =
    '<h2>Configure Sentry.</h2>' +
    '<p>You can change any of these later from the Sentry tray icon.</p>' +
    '<div class="grid" style="margin-top:10px;">' +
      '<div class="field"><span class="lbl">Cameras</span>' +
        '<select id="cams">' +
          '<option value="all">Record all detected cameras</option>' +
          '<option value="first">Only the first / built-in camera</option>' +
          '<option value="ask">Ask me on first launch</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Frame rate</span>' +
        '<select id="fps">' +
          '<option value="5">5 fps (tiny files)</option>' +
          '<option value="15">15 fps</option>' +
          '<option value="30" selected>30 fps (recommended)</option>' +
          '<option value="60">60 fps (smooth)</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Audio</span>' +
        '<div class="toggle" id="audToggle">' +
          '<div class="tbtn on" data-v="on">Sound ON</div>' +
          '<div class="tbtn" data-v="off">Silent</div>' +
        '</div></div>' +
      '<div class="field"><span class="lbl">Auto-delete after</span>' +
        '<select id="ret">' +
          '<option value="1">1 day</option>' +
          '<option value="7" selected>7 days</option>' +
          '<option value="30">30 days</option>' +
          '<option value="90">90 days</option>' +
          '<option value="0">Never delete</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Playback speed</span>' +
        '<select id="spd">' +
          '<option value="1" selected>1&times; (realtime)</option>' +
          '<option value="2">2&times;</option>' +
          '<option value="4">4&times;</option>' +
          '<option value="8">8&times;</option>' +
        '</select></div>' +
      '<div class="field"><span class="lbl">Open Sentry at login</span>' +
        '<div class="toggle" id="autoToggle">' +
          '<div class="tbtn on" data-v="1">Open at login (disarmed)</div>' +
          '<div class="tbtn" data-v="0">Open manually only</div>' +
        '</div>' +
        '<p style="margin:6px 0 0;font-size:12px;color:#9aa4d6;">Sentry starts disarmed. It does not record until you press Arm.</p>' +
      '</div>' +
    '</div>' +
    '<div class="actions">' +
      '<button class="btn ghost" onclick="setStep(1)">&larr; Back</button>' +
      '<button class="btn prim" onclick="collectSettings()">Continue &rarr;</button>' +
    '</div>';
  bindToggle("audToggle", "audio");
  bindToggle("autoToggle", "autostart");
}

var pwMode = null; // null | "password" | "none"

function renderPassword() {
  pwMode = null;
  panel.innerHTML =
    '<h2>Protect your footage.</h2>' +
    '<p style="margin-bottom:18px;">Pick one. You can change this later from the Sentry tray icon.</p>' +
    '<div class="pw-mode-grid">' +
      '<button type="button" class="pw-choice" onclick="pickPwMode(\'password\')">' +
        '<div class="pw-choice-icon">&#128274;</div>' +
        '<div class="pw-choice-title">Set a password</div>' +
        '<div class="pw-choice-sub">Required to view, export, or delete clips. Recommended.</div>' +
      '</button>' +
      '<button type="button" class="pw-choice" onclick="pickPwMode(\'none\')">' +
        '<div class="pw-choice-icon">&#128275;</div>' +
        '<div class="pw-choice-title">No password</div>' +
        '<div class="pw-choice-sub">Anyone on this PC can view your footage. Faster to use.</div>' +
      '</button>' +
    '</div>' +
    '<div id="pwBody" style="margin-top:18px;"></div>' +
    '<div class="actions">' +
      '<button class="btn ghost" onclick="setStep(2)">&larr; Back</button>' +
      '<button class="btn prim" id="pwNext" onclick="confirmPassword()" disabled style="opacity:0.45;">Install &rarr;</button>' +
    '</div>';
}

function pickPwMode(mode) {
  pwMode = mode;
  // highlight selected choice
  var choices = document.getElementsByClassName("pw-choice");
  for (var i = 0; i < choices.length; i++) choices[i].className = "pw-choice";
  var picked = (mode === "password") ? choices[0] : choices[1];
  picked.className = "pw-choice on";
  var body = document.getElementById("pwBody");
  var nxt = document.getElementById("pwNext");
  if (mode === "password") {
    body.innerHTML =
      '<div class="pw-stack">' +
        '<div class="pw-row"><span class="lbl">Password</span>' +
          '<input id="pw1" type="password" placeholder="Your password" autocomplete="off" />' +
          '<div class="pw-bar"><div id="pwBar"></div></div>' +
          '<span class="pw-hint" id="pwStrength">strength: &mdash;</span>' +
        '</div>' +
        '<div class="pw-row"><span class="lbl">Confirm password</span>' +
          '<input id="pw2" type="password" placeholder="Type it again" autocomplete="off" />' +
        '</div>' +
        '<label class="showpw"><input type="checkbox" id="pwShow" /> <span>Show passwords</span></label>' +
        '<div class="pw-err" id="pwErr"></div>' +
      '</div>';
    var pw1 = document.getElementById("pw1");
    var pw2 = document.getElementById("pw2");
    var show = document.getElementById("pwShow");
    var bar = document.getElementById("pwBar");
    var strength = document.getElementById("pwStrength");
    function refreshNxt() {
      var ok = pw1.value.length > 0 && pw1.value === pw2.value;
      nxt.disabled = !ok;
      nxt.style.opacity = ok ? 1 : 0.45;
    }
    pw1.onkeyup = function () {
      var v = pw1.value, score = 0, label = "weak";
      if (v.length >= 6) score += 20;
      if (v.length >= 10) score += 20;
      if (/[A-Z]/.test(v)) score += 15;
      if (/[0-9]/.test(v)) score += 15;
      if (/[^A-Za-z0-9]/.test(v)) score += 30;
      if (score >= 70) label = "strong";
      else if (score >= 40) label = "decent";
      bar.style.width = Math.min(score, 100) + "%";
      strength.innerHTML = "strength: " + label;
      refreshNxt();
    };
    pw2.onkeyup = refreshNxt;
    show.onclick = function () {
      var t = show.checked ? "text" : "password";
      pw1.type = t; pw2.type = t;
    };
    pw1.focus();
    nxt.disabled = true; nxt.style.opacity = 0.45;
  } else {
    body.innerHTML =
      '<div class="pw-none">' +
        '<p><b>No password will be required.</b> Sentry will start recording immediately on install. Your clips in <code>%USERPROFILE%\\Sentry</code> will be accessible to anyone signed into this Windows account.</p>' +
        '<button type="button" class="btn prim" onclick="confirmPassword()" style="margin-top:8px;">Continue without password &rarr;</button>' +
      '</div>';
    // main next button also enabled so user has two equivalent paths
    nxt.disabled = false; nxt.style.opacity = 1;
  }
}

function confirmPassword() {
  if (pwMode === "none") {
    settings.passwordB64 = "";
    setStep(4);
    setTimeout(runInstall, 250);
    return;
  }
  if (pwMode !== "password") return;
  var pw1 = document.getElementById("pw1").value;
  var pw2 = document.getElementById("pw2").value;
  var err = document.getElementById("pwErr");
  err.innerHTML = "";
  if (pw1.length === 0) { err.innerHTML = "Enter a password, or go back and pick \'No password\'."; return; }
  if (pw1 !== pw2) { err.innerHTML = "Passwords don\'t match."; return; }
  try {
    settings.passwordB64 = window.btoa(unescape(encodeURIComponent(pw1)));
  } catch (e) {
    settings.passwordB64 = pw1;
  }
  setStep(4);
  setTimeout(runInstall, 250);
}

function bindToggle(groupId, key) {
  var group = document.getElementById(groupId);
  var btns = group.getElementsByTagName("div");
  for (var i = 0; i < btns.length; i++) {
    (function (b) {
      b.onclick = function () {
        for (var j = 0; j < btns.length; j++) btns[j].className = "tbtn";
        b.className = "tbtn on";
        var v = b.getAttribute("data-v");
        if (key === "autostart") {
          settings[key] = (v === "1");
        } else {
          settings[key] = v;
        }
      };
    })(btns[i]);
  }
}

function collectSettings() {
  settings.cameras = document.getElementById("cams").value;
  settings.fps = parseInt(document.getElementById("fps").value, 10);
  settings.retention = parseInt(document.getElementById("ret").value, 10);
  settings.speed = parseFloat(document.getElementById("spd").value);
  setStep(3);
}

function renderInstall() {
  panel.innerHTML =
    '<h2>Installing Sentry...</h2>' +
    '<p>This usually takes about 3 seconds.</p>' +
    '<pre id="log"></pre>';
}

function log(line, cls) {
  var el = document.getElementById("log");
  if (!el) return;
  var span = document.createElement("span");
  if (cls) span.className = cls;
  span.innerHTML = line + "\n";
  el.appendChild(span);
  el.scrollTop = el.scrollHeight;
}

function sleep(ms) {
  var start = new Date().getTime();
  while (new Date().getTime() - start < ms) { /* block briefly */ }
}

function runInstall() {
  try {
    var installDir = GetInstallDir();
    var dataDir = GetDataDir();

    log("&#10003; Creating install directory", "ok");
    EnsureDir(installDir);
    EnsureDir(installDir + "\\logs");
    EnsureDir(dataDir);
    sleep(180);

    log("&#10003; Writing configuration", "ok");
    var cfg = buildConfig();
    WriteTextFile(installDir + "\\sentry.config.json", cfg);
    sleep(180);

    log("&#10003; Installing recorder engine", "ok");
    WriteTextFile(installDir + "\\sentry.ps1", buildRecorderScript());
    WriteTextFile(installDir + "\\sentry-launch.vbs", buildLauncherScript());
    WriteTextFile(installDir + "\\uninstall.vbs", buildUninstaller());
    sleep(150);

    log("&#10003; Installing Sentry app", "ok");
    WriteTextFile(installDir + "\\Sentry.hta", buildDashboardHta());
    sleep(150);

    log("&#10003; Detected cameras: <span class='hl'>scan deferred to arm time</span>", "ok");
    sleep(120);

    var sh = new ActiveXObject("WScript.Shell");
    var desktop = sh.SpecialFolders("Desktop");
    var startup = sh.SpecialFolders("Startup");
    var startMenu = sh.SpecialFolders("Programs");
    var mshta = sh.ExpandEnvironmentStrings("%SystemRoot%") + "\\System32\\mshta.exe";
    var dashArgs = '"' + installDir + '\\Sentry.hta"';

    if (settings.desktopShortcut) {
      log("&#10003; Creating desktop shortcut", "ok");
      CreateShortcut(mshta, desktop + "\\Sentry.lnk", dashArgs, mshta);
      sleep(120);
    }

    // Start Menu entry so Windows Search finds "Sentry"
    log("&#10003; Adding to Start Menu (Windows search)", "ok");
    EnsureDir(startMenu + "\\Sentry");
    CreateShortcut(mshta, startMenu + "\\Sentry\\Sentry.lnk", dashArgs, mshta);
    CreateShortcut("wscript.exe",
      startMenu + "\\Sentry\\Sentry Uninstaller.lnk",
      '"' + installDir + '\\uninstall.vbs"', "");
    sleep(120);

    if (settings.autostart) {
      log("&#10003; Opening Sentry at Windows login (disarmed)", "ok");
      CreateShortcut(mshta, startup + "\\Sentry.lnk", dashArgs, mshta);
      sleep(120);
    }

    log("&#10003; Applied: <span class='hl'>" + settings.fps + " fps &middot; audio " + settings.audio + " &middot; retain " +
        (settings.retention === 0 ? "forever" : settings.retention + "d") + "</span>", "ok");
    sleep(120);

    log("Sentry installed. Ready to arm.", "done");
    setTimeout(function () {
      setStep(5);
      launchSentry();
    }, 700);
  } catch (err) {
    log("&#10007; " + err.message, "");
  }
}

function launchSentry() {
  try {
    var sh3 = new ActiveXObject("WScript.Shell");
    var mshta = sh3.ExpandEnvironmentStrings("%SystemRoot%") + "\\System32\\mshta.exe";
    var installDir = GetInstallDir();
    sh3.Run('"' + mshta + '" "' + installDir + '\\Sentry.hta"', 1, false);
  } catch (e) {
    try { alert("Couldn't launch Sentry: " + e.message + "\nUse the Start Menu shortcut."); } catch (_) {}
  }
}

function buildConfig() {
  return '{\n' +
    '  "version": "1.0",\n' +
    '  "cameras": "' + settings.cameras + '",\n' +
    '  "fps": ' + settings.fps + ',\n' +
    '  "audio": "' + settings.audio + '",\n' +
    '  "retentionDays": ' + settings.retention + ',\n' +
    '  "playbackSpeed": ' + settings.speed + ',\n' +
    '  "autostart": ' + (settings.autostart ? "true" : "false") + ',\n' +
    '  "outputDir": "%USERPROFILE%\\\\Sentry",\n' +
    '  "clipSeconds": 60,\n' +
    '  "passwordB64": "' + settings.passwordB64 + '"\n' +
    '}\n';
}

function buildLauncherScript() {
  // VBS launcher runs PowerShell completely hidden
  return 'Set sh = CreateObject("WScript.Shell")\r\n' +
    'installDir = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") & "\\Sentry"\r\n' +
    'sh.Run "powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File """ & installDir & "\\sentry.ps1""", 0, False\r\n';
}

function buildUninstaller() {
  return 'Set sh = CreateObject("WScript.Shell")\r\n' +
    'Set fso = CreateObject("Scripting.FileSystemObject")\r\n' +
    'installDir = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") & "\\Sentry"\r\n' +
    'desktop = sh.SpecialFolders("Desktop")\r\n' +
    'startup = sh.SpecialFolders("Startup")\r\n' +
    'programs = sh.SpecialFolders("Programs")\r\n' +
    'On Error Resume Next\r\n' +
    'If fso.FileExists(desktop & "\\Sentry.lnk") Then fso.DeleteFile desktop & "\\Sentry.lnk"\r\n' +
    'If fso.FileExists(startup & "\\Sentry.lnk") Then fso.DeleteFile startup & "\\Sentry.lnk"\r\n' +
    'If fso.FolderExists(programs & "\\Sentry") Then fso.DeleteFolder programs & "\\Sentry", True\r\n' +
    'If fso.FolderExists(installDir) Then fso.DeleteFolder installDir, True\r\n' +
    'MsgBox "Sentry has been uninstalled.", 64, "Sentry"\r\n';
}

function buildDashboardHta() {
  var L = [];
  L.push('<!DOCTYPE html><html><head>');
  L.push('<title>Sentry</title>');
  L.push('<meta http-equiv="Content-Type" content="text/html; charset=utf-8">');
  L.push('<meta http-equiv="x-ua-compatible" content="ie=edge">');
  L.push('<HTA:APPLICATION ID="SentryApp" APPLICATIONNAME="Sentry" BORDER="dialog" CAPTION="yes" SCROLL="no" SINGLEINSTANCE="yes" SYSMENU="yes" MAXIMIZEBUTTON="no" WINDOWSTATE="normal" SHOWINTASKBAR="yes" />');
  L.push('<style>');
  L.push('html,body{margin:0;padding:0;height:100%;font-family:"Segoe UI",Inter,Arial,sans-serif;color:#f3f3ff;overflow:hidden;background:radial-gradient(circle at 15% 10%,rgba(255,46,136,0.22),transparent 45%),radial-gradient(circle at 85% 90%,rgba(34,211,238,0.18),transparent 50%),linear-gradient(180deg,#06060e 0%,#0b0c1c 100%);}');
  L.push('.v{height:100%;box-sizing:border-box;display:flex;flex-direction:column;padding:28px;gap:18px;}');
  L.push('.title{font-size:34px;font-weight:900;letter-spacing:-1.5px;margin:0;color:#ff2e88;background:linear-gradient(135deg,#ff2e88,#8b5cf6 50%,#22d3ee);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}');
  L.push('.sub{color:#bfc3e4;font-size:13px;margin:0;}');
  L.push('.status{display:inline-flex;align-items:center;gap:8px;padding:10px 16px;border-radius:999px;font-family:Consolas,monospace;font-size:12px;letter-spacing:1.6px;text-transform:uppercase;border:1px solid;}');
  L.push('.status.ok{background:rgba(57,255,20,0.08);border-color:rgba(57,255,20,0.4);color:#a7ffb0;}');
  L.push('.status.off{background:rgba(154,164,214,0.08);border-color:rgba(154,164,214,0.3);color:#c0c6e5;}');
  L.push('.status.rec{background:rgba(255,51,85,0.1);border-color:rgba(255,51,85,0.5);color:#ffb0bd;}');
  L.push('.d{width:9px;height:9px;border-radius:50%;background:#9aa4d6;}');
  L.push('.status.rec .d{background:#ff3355;box-shadow:0 0 10px #ff3355;animation:p 1.2s infinite;}');
  L.push('@keyframes p{0%,100%{opacity:1}50%{opacity:0.35}}');
  L.push('.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}');
  L.push('.s{padding:14px;border-radius:12px;background:rgba(13,14,28,0.7);border:1px solid rgba(139,92,246,0.25);}');
  L.push('.s .k{font-family:Consolas,monospace;font-size:10px;letter-spacing:1.4px;text-transform:uppercase;color:#c0b0ec;margin-bottom:6px;}');
  L.push('.s .v2{font-size:20px;font-weight:800;color:#22d3ee;font-family:Consolas,monospace;}');
  L.push('.big-arm{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;}');
  L.push('.arm-btn{padding:26px 60px;border:0;border-radius:18px;font-size:24px;font-weight:900;letter-spacing:3px;cursor:pointer;color:#fff;background-color:#ff2e88;background-image:linear-gradient(135deg,#ff2e88,#8b5cf6);box-shadow:0 14px 50px rgba(255,46,136,0.45);transition:transform 0.15s;}');
  L.push('.arm-btn:hover{transform:scale(1.04);}');
  L.push('.arm-note{color:#9aa4d6;font-size:12px;font-family:Consolas,monospace;letter-spacing:1.4px;text-transform:uppercase;}');
  L.push('.bar{display:flex;gap:8px;flex-wrap:wrap;}');
  L.push('.b{padding:9px 16px;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.03);color:#d7dcff;}');
  L.push('.b:hover{border-color:#22d3ee;}');
  L.push('/* armed overlay state */');
  L.push('body.armed{background:linear-gradient(180deg,#0a0208 0%,#180612 100%);}');
  L.push('.armed-v{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;padding:40px;gap:20px;}');
  L.push('body.armed .armed-v{display:flex;}');
  L.push('body.armed .disarmed-v{display:none;}');
  L.push('.armed-title{font-size:64px;font-weight:900;letter-spacing:8px;margin:0;color:#ff3355;text-shadow:0 0 40px rgba(255,51,85,0.6);}');
  L.push('.armed-rec{font-family:Consolas,monospace;font-size:14px;letter-spacing:3px;color:#ffb0bd;display:flex;align-items:center;gap:10px;}');
  L.push('.armed-rec .rd{width:12px;height:12px;border-radius:50%;background:#ff3355;box-shadow:0 0 12px #ff3355;animation:p 1.2s infinite;}');
  L.push('.armed-timer{font-family:Consolas,monospace;font-size:48px;color:#22d3ee;letter-spacing:4px;}');
  L.push('.disarm-btn{margin-top:20px;padding:24px 80px;border:0;border-radius:18px;font-size:26px;font-weight:900;letter-spacing:4px;cursor:pointer;color:#fff;background-color:#ff3355;background-image:linear-gradient(135deg,#ff3355,#8b5cf6);box-shadow:0 14px 60px rgba(255,51,85,0.5);}');
  L.push('.disarm-btn:hover{transform:scale(1.04);}');
  L.push('.live{position:fixed;right:18px;bottom:18px;width:320px;height:240px;border-radius:14px;overflow:hidden;background:#000;border:2px solid rgba(255,51,85,0.7);box-shadow:0 0 40px rgba(255,51,85,0.3);display:flex;flex-direction:column;}');
  L.push('.live .lh{padding:6px 10px;background:rgba(0,0,0,0.8);font-family:Consolas,monospace;font-size:10px;letter-spacing:2px;color:#ffb0bd;display:flex;align-items:center;gap:6px;}');
  L.push('.live .lh .rd{width:7px;height:7px;border-radius:50%;background:#ff3355;box-shadow:0 0 6px #ff3355;animation:p 1.2s infinite;}');
  L.push('.live img{flex:1;width:100%;object-fit:cover;background:#000;}');
  L.push('.live .nocam{flex:1;display:flex;align-items:center;justify-content:center;color:#9aa4d6;font-size:11px;font-family:Consolas,monospace;}');
  L.push('.gate{position:fixed;inset:0;background:rgba(5,6,14,0.96);display:none;align-items:center;justify-content:center;flex-direction:column;gap:14px;padding:30px;}');
  L.push('.gate.show{display:flex;}');
  L.push('.gate h2{margin:0;font-size:28px;}');
  L.push('.gate input{background:#12132a;border:1px solid rgba(255,255,255,0.18);color:#fff;padding:14px 16px;border-radius:10px;font-size:15px;width:320px;outline:none;}');
  L.push('.gate input:focus{border-color:#ff2e88;}');
  L.push('.gate .err{color:#ff6b8a;font-size:13px;min-height:1em;}');
  L.push('.gate .row{display:flex;gap:10px;}');
  L.push('.gate button{padding:12px 22px;border:0;border-radius:10px;font-weight:700;cursor:pointer;}');
  L.push('.gate .p{background-color:#ff3355;background-image:linear-gradient(135deg,#ff3355,#8b5cf6);color:#fff;}');
  L.push('.gate .g{background:transparent;border:1px solid rgba(255,255,255,0.15);color:#d7dcff;}');
  L.push('</style></head><body>');
  L.push('<div class="v disarmed-v">');
  L.push('<h1 class="title">SENTRY</h1>');
  L.push('<div class="status off" id="statusPill"><span class="d"></span><span id="statusText">Disarmed</span></div>');
  L.push('<div class="stats">');
  L.push('<div class="s"><div class="k">Stored clips</div><div class="v2" id="clipCount">0</div></div>');
  L.push('<div class="s"><div class="k">Disk used</div><div class="v2" id="diskUsed">0 MB</div></div>');
  L.push('<div class="s"><div class="k">Cameras</div><div class="v2" id="camCount">&mdash;</div></div>');
  L.push('</div>');
  L.push('<div class="big-arm">');
  L.push('<div class="arm-note">Press Arm to begin recording</div>');
  L.push('<button class="arm-btn" onclick="doArm()">ARM SENTRY</button>');
  L.push('<div class="arm-note" style="color:#c0b0ec;">Sentry will lock this screen and require your password to disarm.</div>');
  L.push('</div>');
  L.push('<div class="bar">');
  L.push('<button class="b" onclick="openFolder()">Open footage folder</button>');
  L.push('<button class="b" onclick="openConfig()">Edit config</button>');
  L.push('<button class="b" onclick="uninstallNow()" style="color:#ffb0bd;border-color:rgba(255,51,85,0.35);">Uninstall</button>');
  L.push('</div>');
  L.push('</div>');
  L.push('<div class="armed-v">');
  L.push('<div class="armed-rec"><span class="rd"></span> RECORDING &middot; <span id="armedCamCount">0</span> CAMERAS</div>');
  L.push('<h1 class="armed-title">ARMED</h1>');
  L.push('<div class="armed-timer" id="armedTimer">00:00:00</div>');
  L.push('<button class="disarm-btn" onclick="askDisarm()">DISARM</button>');
  L.push('<div class="live" id="livePanel">');
  L.push('<div class="lh"><span class="rd"></span> LIVE &middot; CAM</div>');
  L.push('<img id="liveImg" src="" alt="" />');
  L.push('<div class="nocam" id="liveNoCam" style="display:none;">Waiting for camera feed...</div>');
  L.push('</div>');
  L.push('</div>');
  L.push('<div class="gate" id="gate">');
  L.push('<h2>Disarm Sentry</h2>');
  L.push('<p class="sub" id="gateSub">Enter your password to stop recording.</p>');
  L.push('<input id="gateInput" type="password" placeholder="Password" />');
  L.push('<div class="err" id="gateErr"></div>');
  L.push('<div class="row"><button class="g" onclick="closeGate()">Cancel</button><button class="p" onclick="tryDisarm()">Disarm</button></div>');
  L.push('</div>');
  L.push('<' + 'script>');
  L.push('var sh=new ActiveXObject("WScript.Shell"), fso=new ActiveXObject("Scripting.FileSystemObject");');
  L.push('var installDir=sh.ExpandEnvironmentStrings("%LOCALAPPDATA%")+"\\\\Sentry";');
  L.push('var dataDir=sh.ExpandEnvironmentStrings("%USERPROFILE%")+"\\\\Sentry";');
  L.push('var pidFile=installDir+"\\\\sentry.pid";');
  L.push('var liveFile=installDir+"\\\\live.jpg";');
  L.push('var armFlag=installDir+"\\\\arm.flag";');
  L.push('var cfg={}, armedStart=null, previewTimer=null, tickTimer=null;');
  L.push('function readCfg(){ try{ var ts=fso.OpenTextFile(installDir+"\\\\sentry.config.json",1); var t=ts.ReadAll(); ts.Close(); return eval("("+t+")"); }catch(e){ return {}; } }');
  L.push('function writeText(path,content){ var ts=fso.CreateTextFile(path,true); ts.Write(content); ts.Close(); }');
  L.push('function humanBytes(n){ if(n<1024) return n+" B"; if(n<1048576) return (n/1024).toFixed(1)+" KB"; if(n<1073741824) return (n/1048576).toFixed(1)+" MB"; return (n/1073741824).toFixed(2)+" GB"; }');
  L.push('function countCameras(){');
  L.push(' try{');
  L.push('  var wmi=GetObject("winmgmts:\\\\\\\\.\\\\root\\\\cimv2");');
  L.push('  var q=wmi.ExecQuery("Select Name,PNPClass,Service from Win32_PnPEntity");');
  L.push('  var e=new Enumerator(q); var n=0;');
  L.push('  for(;!e.atEnd();e.moveNext()){ var o=e.item(); if(o.PNPClass=="Camera"||o.Service=="usbvideo") n++; }');
  L.push('  return n;');
  L.push(' }catch(e){ return 0; }');
  L.push('}');
  L.push('function refreshStats(){');
  L.push(' try{');
  L.push('  var fe=new Enumerator(fso.GetFolder(dataDir).Files); var count=0,bytes=0;');
  L.push('  for(;!fe.atEnd();fe.moveNext()){ count++; bytes+=fe.item().Size; }');
  L.push('  document.getElementById("clipCount").innerHTML=count;');
  L.push('  document.getElementById("diskUsed").innerHTML=humanBytes(bytes);');
  L.push(' }catch(e){}');
  L.push(' var cn=countCameras();');
  L.push(' document.getElementById("camCount").innerHTML=cn;');
  L.push(' var ac=document.getElementById("armedCamCount"); if(ac) ac.innerHTML=cn;');
  L.push('}');
  L.push('function openFolder(){ sh.Run("explorer.exe \\""+dataDir+"\\"",1,false); }');
  L.push('function openConfig(){ sh.Run("notepad.exe \\""+installDir+"\\\\sentry.config.json\\"",1,false); }');
  L.push('function uninstallNow(){ if(confirm("Uninstall Sentry? Recorded clips will be kept in "+dataDir+".")){ sh.Run("wscript.exe \\""+installDir+"\\\\uninstall.vbs\\"",1,false); window.close(); } }');
  L.push('function doArm(){');
  L.push(' try{ writeText(armFlag,"armed "+(new Date()).toString()); }catch(e){}');
  L.push(' try{ sh.Run("wscript.exe \\""+installDir+"\\\\sentry-launch.vbs\\"",0,false); }catch(e){ alert("Failed to start recorder: "+e.message); return; }');
  L.push(' document.body.className="armed";');
  L.push(' try{ window.resizeTo(screen.availWidth,screen.availHeight); window.moveTo(0,0); }catch(e){}');
  L.push(' armedStart=new Date();');
  L.push(' if(tickTimer) clearInterval(tickTimer);');
  L.push(' tickTimer=setInterval(tick,1000);');
  L.push(' if(previewTimer) clearInterval(previewTimer);');
  L.push(' previewTimer=setInterval(refreshPreview,600);');
  L.push(' refreshPreview();');
  L.push('}');
  L.push('function askDisarm(){');
  L.push(' if(!cfg.passwordB64){ performDisarm(); return; }');
  L.push(' document.getElementById("gate").className="gate show";');
  L.push(' document.getElementById("gateInput").value="";');
  L.push(' document.getElementById("gateErr").innerHTML="";');
  L.push(' setTimeout(function(){ try{ document.getElementById("gateInput").focus(); }catch(e){} },50);');
  L.push('}');
  L.push('function closeGate(){ document.getElementById("gate").className="gate"; }');
  L.push('function tryDisarm(){');
  L.push(' var v=document.getElementById("gateInput").value;');
  L.push(' var b64=""; try{ b64=window.btoa(unescape(encodeURIComponent(v))); }catch(e){ b64=v; }');
  L.push(' if(b64===cfg.passwordB64){ closeGate(); performDisarm(); } else { document.getElementById("gateErr").innerHTML="Wrong password."; }');
  L.push('}');
  L.push('function performDisarm(){');
  L.push(' try{');
  L.push('  if(fso.FileExists(pidFile)){');
  L.push('   var ts=fso.OpenTextFile(pidFile,1); var pid=ts.ReadAll(); ts.Close();');
  L.push('   pid=(pid+"").replace(/[^0-9]/g,"");');
  L.push('   if(pid) sh.Run("taskkill /F /T /PID "+pid,0,true);');
  L.push('   try{ fso.DeleteFile(pidFile); }catch(e){}');
  L.push('  }');
  L.push('  sh.Run("taskkill /F /IM ffmpeg.exe",0,false);');
  L.push(' }catch(e){}');
  L.push(' try{ if(fso.FileExists(armFlag)) fso.DeleteFile(armFlag); }catch(e){}');
  L.push(' if(previewTimer){ clearInterval(previewTimer); previewTimer=null; }');
  L.push(' if(tickTimer){ clearInterval(tickTimer); tickTimer=null; }');
  L.push(' document.body.className="";');
  L.push(' try{ window.resizeTo(780,620); window.moveTo(Math.max(0,(screen.availWidth-780)/2),Math.max(0,(screen.availHeight-620)/2)); }catch(e){}');
  L.push(' refreshStats();');
  L.push('}');
  L.push('function tick(){');
  L.push(' if(!armedStart) return;');
  L.push(' var s=Math.floor((new Date()-armedStart)/1000);');
  L.push(' var h=Math.floor(s/3600), m=Math.floor((s%3600)/60), x=s%60;');
  L.push(' function pad(n){ return (n<10?"0":"")+n; }');
  L.push(' document.getElementById("armedTimer").innerHTML=pad(h)+":"+pad(m)+":"+pad(x);');
  L.push('}');
  L.push('function refreshPreview(){');
  L.push(' var img=document.getElementById("liveImg");');
  L.push(' var no=document.getElementById("liveNoCam");');
  L.push(' if(fso.FileExists(liveFile)){ img.style.display=""; no.style.display="none"; img.src="file:///"+liveFile.replace(/\\\\/g,"/")+"?t="+(new Date().getTime()); }');
  L.push(' else { img.style.display="none"; no.style.display="flex"; }');
  L.push('}');
  L.push('try{ window.resizeTo(780,620); window.moveTo(Math.max(0,(screen.availWidth-780)/2),Math.max(0,(screen.availHeight-620)/2)); }catch(e){}');
  L.push('cfg=readCfg(); refreshStats(); setInterval(refreshStats,5000);');
  L.push('<' + '/script></body></html>');
  return L.join("\r\n");
}

function buildRecorderScript() {
  // PowerShell recorder: runs only while armed (spawned by dashboard).
  // Writes its own PID so dashboard can kill it on disarm, records clips,
  // writes live.jpg every second for the bottom-right preview, purges old clips.
  return "# Sentry recorder - generated by installer\r\n" +
    "$ErrorActionPreference = 'SilentlyContinue'\r\n" +
    "$installDir = Join-Path $env:LOCALAPPDATA 'Sentry'\r\n" +
    "$dataDir = Join-Path $env:USERPROFILE 'Sentry'\r\n" +
    "$logFile = Join-Path $installDir 'logs\\sentry.log'\r\n" +
    "$cfgPath = Join-Path $installDir 'sentry.config.json'\r\n" +
    "$pidFile = Join-Path $installDir 'sentry.pid'\r\n" +
    "$liveFile = Join-Path $installDir 'live.jpg'\r\n" +
    "$armFlag = Join-Path $installDir 'arm.flag'\r\n" +
    "function Log($m) { Add-Content -Path $logFile -Value ((Get-Date -Format s) + ' ' + $m) }\r\n" +
    "Set-Content -Path $pidFile -Value $PID -Force\r\n" +
    "if (-not (Test-Path $dataDir)) { New-Item -ItemType Directory -Path $dataDir -Force | Out-Null }\r\n" +
    "$cfg = Get-Content $cfgPath -Raw | ConvertFrom-Json\r\n" +
    "$ret = [int]$cfg.retentionDays\r\n" +
    "$fps = [int]$cfg.fps\r\n" +
    "$audio = $cfg.audio\r\n" +
    "$clipSec = [int]$cfg.clipSeconds\r\n" +
    "Log \"sentry armed fps=$fps audio=$audio retention=$ret pid=$PID\"\r\n" +
    "function Get-Cameras {\r\n" +
    "  Get-CimInstance -ClassName Win32_PnPEntity |\r\n" +
    "    Where-Object { $_.PNPClass -eq 'Camera' -or $_.Service -eq 'usbvideo' } |\r\n" +
    "    Select-Object -ExpandProperty Name\r\n" +
    "}\r\n" +
    "function Find-FFmpeg {\r\n" +
    "  $c1 = Join-Path $installDir 'ffmpeg.exe'\r\n" +
    "  if (Test-Path $c1) { return $c1 }\r\n" +
    "  try { $r = Get-Command ffmpeg.exe -ErrorAction Stop; return $r.Source } catch { return $null }\r\n" +
    "}\r\n" +
    "function Ensure-FFmpeg {\r\n" +
    "  $existing = Find-FFmpeg\r\n" +
    "  if ($existing) { return $existing }\r\n" +
    "  $stateFile = Join-Path $installDir 'ffmpeg.state'\r\n" +
    "  Set-Content -Path $stateFile -Value 'downloading' -Force\r\n" +
    "  Log 'ffmpeg missing; downloading recorder engine'\r\n" +
    "  $zipUrl = 'https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-essentials.zip'\r\n" +
    "  $zipPath = Join-Path $installDir 'ffmpeg.zip'\r\n" +
    "  $extractDir = Join-Path $installDir 'ffmpeg-src'\r\n" +
    "  try {\r\n" +
    "    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12\r\n" +
    "    Invoke-WebRequest -Uri $zipUrl -OutFile $zipPath -UseBasicParsing -TimeoutSec 300\r\n" +
    "    if (Test-Path $extractDir) { Remove-Item $extractDir -Recurse -Force }\r\n" +
    "    Expand-Archive -Path $zipPath -DestinationPath $extractDir -Force\r\n" +
    "    $binary = Get-ChildItem -Path $extractDir -Filter 'ffmpeg.exe' -Recurse | Select-Object -First 1\r\n" +
    "    if ($binary) {\r\n" +
    "      Copy-Item -Path $binary.FullName -Destination (Join-Path $installDir 'ffmpeg.exe') -Force\r\n" +
    "      Remove-Item $zipPath -Force\r\n" +
    "      Remove-Item $extractDir -Recurse -Force\r\n" +
    "      Set-Content -Path $stateFile -Value 'ok' -Force\r\n" +
    "      Log 'ffmpeg downloaded and installed'\r\n" +
    "      return (Join-Path $installDir 'ffmpeg.exe')\r\n" +
    "    }\r\n" +
    "    Set-Content -Path $stateFile -Value 'extract_failed' -Force\r\n" +
    "    Log 'ffmpeg.exe not found inside downloaded archive'\r\n" +
    "    return $null\r\n" +
    "  } catch {\r\n" +
    "    Set-Content -Path $stateFile -Value ('error: ' + $_.Exception.Message) -Force\r\n" +
    "    Log ('ffmpeg download failed: ' + $_.Exception.Message)\r\n" +
    "    return $null\r\n" +
    "  }\r\n" +
    "}\r\n" +
    "function Purge-Old {\r\n" +
    "  if ($ret -le 0) { return }\r\n" +
    "  $cutoff = (Get-Date).AddDays(-$ret)\r\n" +
    "  Get-ChildItem -Path $dataDir -Filter 'sentry_*.*' -File |\r\n" +
    "    Where-Object { $_.LastWriteTime -lt $cutoff } |\r\n" +
    "    ForEach-Object { Remove-Item $_.FullName -Force; Log (\"purged \" + $_.Name) }\r\n" +
    "}\r\n" +
    "# One-time cleanup: remove placeholder .txt files from older versions\r\n" +
    "Get-ChildItem -Path $dataDir -Filter 'sentry_*.txt' -File -ErrorAction SilentlyContinue |\r\n" +
    "  ForEach-Object { Remove-Item $_.FullName -Force; Log (\"cleanup: \" + $_.Name) }\r\n" +
    "$ffmpeg = Ensure-FFmpeg\r\n" +
    "try {\r\n" +
    "  while (Test-Path $armFlag) {\r\n" +
    "    if (-not $ffmpeg) {\r\n" +
    "      Log 'cannot record: ffmpeg not available; retrying download in 60s'\r\n" +
    "      Start-Sleep -Seconds 60\r\n" +
    "      $ffmpeg = Ensure-FFmpeg\r\n" +
    "      continue\r\n" +
    "    }\r\n" +
    "    $cams = @(Get-Cameras)\r\n" +
    "    if (-not $cams -or $cams.Count -eq 0) { Log 'no cameras detected'; Start-Sleep -Seconds 5; continue }\r\n" +
    "    $cam = $cams[0]\r\n" +
    "    $ts = Get-Date -Format 'yyyy-MM-dd_HH-mm-ss'\r\n" +
    "    $safe = ($cam -replace '[^a-zA-Z0-9]', '_')\r\n" +
    "    $out = Join-Path $dataDir (\"sentry_${safe}_${ts}.avi\")\r\n" +
    "    $audioArgs = @()\r\n" +
    "    if ($audio -eq 'on') { $audioArgs = @('-f','dshow','-i','audio=default') }\r\n" +
    "    $ffArgs = @('-y','-f','dshow','-framerate',$fps,'-i',\"video=$cam\") + $audioArgs +\r\n" +
    "      @('-map','0:v','-c:v','mjpeg','-t',$clipSec,$out,\r\n" +
    "        '-map','0:v','-vf','fps=1','-update','1',$liveFile)\r\n" +
    "    Start-Process -FilePath $ffmpeg -ArgumentList $ffArgs -NoNewWindow -Wait\r\n" +
    "    Purge-Old\r\n" +
    "  }\r\n" +
    "} finally {\r\n" +
    "  try { Remove-Item $pidFile -Force } catch {}\r\n" +
    "  Log 'sentry disarmed'\r\n" +
    "}\r\n";
}


function renderDone() {
  panel.innerHTML =
    '<div class="done-banner">' +
      '<div class="big">Sentry is watching.</div>' +
      '<p>Installed to <code>%LOCALAPPDATA%\\Sentry</code>. Clips will appear in <code>%USERPROFILE%\\Sentry</code>.</p>' +
    '</div>' +
    '<div class="grid" style="margin-top:6px;">' +
      '<div class="field"><span class="lbl">Desktop shortcut</span><p style="margin:0;">Created. Double-click "Sentry" to start/stop manually.</p></div>' +
      '<div class="field"><span class="lbl">Startup</span><p style="margin:0;">' + (settings.autostart ? "Will start with Windows." : "Manual start only.") + '</p></div>' +
      '<div class="field"><span class="lbl">Uninstall</span><p style="margin:0;">Run <code>uninstall.vbs</code> in the install folder anytime.</p></div>' +
      '<div class="field"><span class="lbl">Need help?</span><p style="margin:0;"><a style="color:#22d3ee;" href="https://blackboxadvancements.com/sentry">blackboxadvancements.com/sentry</a></p></div>' +
    '</div>' +
    '<div class="actions">' +
      '<button class="btn ghost" onclick="openFolder()">Open Folder</button>' +
      '<button class="btn ghost" onclick="launchSentry()">Open Sentry</button>' +
      '<button class="btn prim" onclick="launchSentry(); window.close();">Launch &amp; Finish</button>' +
    '</div>';
}

function openFolder() {
  try {
    var sh = new ActiveXObject("WScript.Shell");
    sh.Run('explorer.exe "' + sh.ExpandEnvironmentStrings("%USERPROFILE%\\Sentry") + '"', 1, false);
  } catch (e) { }
}

// size window, center, and enforce a minimum size for the entire setup
var MIN_W = 760;
var MIN_H = 700;
function enforceSize() {
  try {
    var w = window.outerWidth || document.documentElement.clientWidth;
    var h = window.outerHeight || document.documentElement.clientHeight;
    var nw = w, nh = h;
    if (w < MIN_W) nw = MIN_W;
    if (h < MIN_H) nh = MIN_H;
    if (nw !== w || nh !== h) window.resizeTo(nw, nh);
  } catch (e) { }
}
try {
  window.resizeTo(MIN_W, MIN_H);
  window.moveTo(
    Math.max(0, (screen.availWidth - MIN_W) / 2),
    Math.max(0, (screen.availHeight - MIN_H) / 2)
  );
} catch (e) { }
window.onresize = enforceSize;
setInterval(enforceSize, 400);

render();
</script>
</body>
</html>
